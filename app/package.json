{
  "name": "payroll-os-app",
  "version": "0.0.1",
  "private": true,
  "description": "payroll-os desktop GUI (Electron + React + TS)",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "pack:dir": "electron-vite build && electron-builder --dir",
    "pack:win": "electron-vite build && electron-builder --win"
  },
  "overrides": {
    "app-builder-lib": {
      "@noble/hashes": "^1.8.0"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.2",
    "electron-vite": "^2.3.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "chokidar": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
